JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_MINUTES=10080
# Use true behind HTTPS in production (Secure cookie flag).
AUTH_COOKIE_SECURE=false
# Persist rate-limit counters in the DB (recommended).
RATE_LIMIT_PERSIST=true
# Optional: LLM refinement pass after keyword CV matching (costs API calls).
CV_LLM_ENRICH=false
# One LLM pass: role suggestions + short CV evaluator (strengths/weaknesses/fit). Recommended on.
CV_LLM_SCREENING=true
# Optional: model override for CV screening only (empty = same as LLM_MODEL).
CV_SCREENING_MODEL=
# Optional: shared rate limits across instances (leave empty to use DB or memory).
REDIS_URL=

DATABASE_URL=sqlite:///./test.db
# Alembic migrations apply on startup. Manual CLI (from backend/): alembic upgrade head

# Required at runtime; tests may mock the client. Empty/invalid keys fail live RAG/LLM calls.
OPENAI_API_KEY=sk-...

LLM_MODEL=gpt-4o-mini
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
EMBEDDING_MODEL=text-embedding-3-small

# Must be writable by the backend process for vector persistence.
CHROMA_DIR=./chroma

# Comma-separated list, e.g. https://your-frontend.com,https://www.your-frontend.com
CORS_ORIGINS=
